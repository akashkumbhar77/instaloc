# InstLoc Environment Configuration
# Copy this file to .env and fill in your actual values

# ===================
# AI API Keys
# ===================

# OpenAI API Key (required for vision extraction)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API Key (optional, fallback)
GEMINI_API_KEY=your-gemini-api-key-here

# ===================
# Google Maps API
# ===================

# Google Maps API Key (required for place grounding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ===================
# Supabase Configuration
# ===================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public)
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key (admin operations - keep secret!)
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Supabase JWT Secret (for validating tokens)
# Get this from Supabase Dashboard: Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ===================
# Database Configuration
# ===================

# For local development with H2 (in-memory)
DB_URL=jdbc:h2:mem:testdb
DB_DRIVER=org.h2.Driver
DB_USER=sa
DB_PASSWORD=
DB_DIALECT=org.hibernate.dialect.H2Dialect

# For PostgreSQL with PostGIS (production)
# DB_URL=jdbc:postgresql://localhost:5432/instaloc
# DB_DRIVER=org.postgresql.Driver
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
